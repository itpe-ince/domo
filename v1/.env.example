# ====================================
# Domo Prototype Environment Variables
# ====================================
# Copy this file to .env and fill in actual values

# --- Database ---
POSTGRES_USER=domo
POSTGRES_PASSWORD=domo_dev_pw
POSTGRES_DB=domo

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (Phase 2 부터 사용) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# --- Firebase (Phase 2~3) ---
FIREBASE_CREDENTIALS_JSON=

# --- URLs ---
FRONTEND_URL=http://localhost:3700
NEXT_PUBLIC_API_URL=http://localhost:3710/v1

# --- Environment ---
ENVIRONMENT=development
NODE_ENV=development
